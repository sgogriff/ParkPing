    <string name="onboarding_title">Private setup</string>
    <string name="onboarding_intro_title">What ParkPing does</string>
    <string name="onboarding_intro_subtitle">ParkPing watches for your arrival at work and puts up a reminder notification so you do not forget to register parking.</string>
    <string name="onboarding_intro_body">When ParkPing thinks you have arrived, it shows a persistent reminder. Once you confirm that parking has been registered, you can mark it done and the reminder will stop for the rest of that workday.</string>
    <string name="onboarding_privacy_title">Private by default</string>
    <string name="onboarding_privacy_subtitle">ParkPing stores your places, Wi-Fi names, and reminder state locally on this device.</string>
    <string name="onboarding_local_title">What stays local</string>
    <string name="onboarding_local_body">Coordinates, place names, SSIDs, reminder state, and language preference stay on your phone. ParkPing does not use an account or cloud backend.</string>
    <string name="onboarding_map_title">Map preview</string>
    <string name="onboarding_map_body">The setup screen loads OpenStreetMap tiles only to show the non-interactive preview map. Core parking data still stays local.</string>
    <string name="onboarding_delete_title">Delete anytime</string>
    <string name="onboarding_delete_body">You can remove ParkPing at any time: Settings > Apps > ParkPing > Uninstall.</string>
    <string name="onboarding_permissions_title">Grant the useful permissions</string>
    <string name="onboarding_permissions_subtitle">Notifications keep the reminder visible. Foreground and background location let Android arm geofences reliably.</string>
    <string name="onboarding_first_place_title">Add a first place</string>
    <string name="onboarding_first_place_subtitle">This part is optional. You can save a place now or skip and finish the rest later in Setup.</string>
    <string name="trigger_terms_title">How arrival detection works</string>
    <string name="trigger_geofence_title">Geofence</string>
    <string name="trigger_geofence_body">A geofence is a virtual boundary around a place. ParkPing asks Android to watch that boundary and trigger a reminder when you enter it.</string>
    <string name="trigger_ssid_title">SSID</string>
    <string name="trigger_ssid_body">An SSID is the name of a Wi-Fi network. If your phone connects to a saved work SSID, ParkPing can use that as another arrival signal and trigger a reminder.</string>

